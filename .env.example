# =============================================
# AI Career Recommendations System - Local Setup
# =============================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/career_ai

# Individual DB settings (optional if DATABASE_URL is set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=career_ai

# Port for API Server (default: 8080)
PORT=8080
